#!/usr/bin/env python3
"""One-shot: email all research report files that were not delivered."""
import glob, os, re, smtplib, sys, time
from email.mime.multipart import MIMEMultipart
from email.mime.text import MIMEText


def _load_dotenv(path="/root/.env"):
    if os.path.exists(path):
        with open(path) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    k, v = line.split("=", 1)
                    os.environ.setdefault(k.strip(), v.strip())


_load_dotenv()

SMTP = {
    "host": "smtp.gmail.com",
    "port": 587,
    "username": os.environ["SMTP_USERNAME"],
    "password": os.environ["SMTP_PASSWORD"],
}
RECIPIENT = os.environ["RECIPIENT_EMAIL"]

# Skip test/scratch files
SKIP = {"nvda-structured-data-test"}


def _md_to_html(md):
    html = re.sub(r"^# (.+)$", r"<h1>\1</h1>", md, flags=re.MULTILINE)
    html = re.sub(r"^## (.+)$", r"<h2>\1</h2>", html, flags=re.MULTILINE)
    html = re.sub(r"^### (.+)$", r"<h3>\1</h3>", html, flags=re.MULTILINE)
    html = re.sub(r"^#### (.+)$", r"<h4>\1</h4>", html, flags=re.MULTILINE)
    html = re.sub(r"\*\*(.+?)\*\*", r"<strong>\1</strong>", html)
    html = re.sub(r"\[([^\]]+)\]\(([^)]+)\)", r'<a href="\2">\1</a>', html)
    html = html.replace("\n", "<br>\n")
    return html


def send_report(filepath):
    slug = os.path.basename(filepath).replace("2026-06-13_standard_", "").replace(".md", "")
    if slug in SKIP:
        print(f"  SKIP {slug}")
        return

    ticker = slug.upper().replace(".HK", ".HK")
    with open(filepath, encoding="utf-8") as f:
        content = f.read()

    subject = f"Research [{ticker}]: Portfolio Standard — 2026-06-13"
    html_body = f"""<html><body style="font-family:Georgia,serif;max-width:800px;margin:0 auto;color:#1a1a1a">
<div style="background:#f5f5f0;padding:16px 20px;border-left:4px solid #2c3e50;margin-bottom:24px">
  <strong style="font-size:16px">Portfolio Research — {ticker}</strong><br>
  <span style="color:#666;font-size:13px">stock &nbsp;|&nbsp; standard &nbsp;|&nbsp; 2026-06-13</span>
</div>
{_md_to_html(content)}
</body></html>"""

    msg = MIMEMultipart("alternative")
    msg["Subject"] = subject
    msg["From"] = SMTP["username"]
    msg["To"] = RECIPIENT
    msg.attach(MIMEText(content, "plain"))
    msg.attach(MIMEText(html_body, "html"))

    with smtplib.SMTP(SMTP["host"], SMTP["port"]) as s:
        s.starttls()
        s.login(SMTP["username"], SMTP["password"])
        s.sendmail(SMTP["username"], RECIPIENT, msg.as_string())
    print(f"  SENT {ticker}")


files = sorted(glob.glob("/root/research/stocks/2026-06-13_standard_*.md"))
print(f"Sending {len(files)} reports to {RECIPIENT} ...")
errors = []
for i, f in enumerate(files, 1):
    slug = os.path.basename(f).replace("2026-06-13_standard_", "").replace(".md", "")
    if slug in SKIP:
        print(f"[{i}/{len(files)}] SKIP {slug}")
        continue
    try:
        print(f"[{i}/{len(files)}] ", end="", flush=True)
        send_report(f)
        time.sleep(0.5)  # brief pause between sends
    except Exception as e:
        print(f"  ERROR {slug}: {e}")
        errors.append((slug, str(e)))

print(f"\nDone. {len(files) - len(errors) - len(SKIP)} sent, {len(errors)} errors.")
if errors:
    for slug, err in errors:
        print(f"  FAILED: {slug} — {err}")
    sys.exit(1)
