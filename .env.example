# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Windmill API (used by scripts/windmill-autopush.py and hooks)
WINDMILL_BASE_URL=http://your-vps-ip:8080
WINDMILL_TOKEN=wmill-api-XXXXXXXXXX

# Gmail SMTP (used by scripts/send_batch_reports.py)
SMTP_USERNAME=your-sender@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Windmill internal PostgreSQL (docker-compose.yml db service)
WM_DB_PASSWORD=your-windmill-db-password

# Portfolio PostgreSQL (used by docker-compose.yml portfolio_postgres service)
PORTFOLIO_DB_PASSWORD=your-db-password

# Report recipient (used by scripts/send_batch_reports.py)
RECIPIENT_EMAIL=your-email@example.com

# Owner identity (referenced in CLAUDE.md "Who You Are Working With" section)
OWNER_NAME=Your Name
OWNER_TITLE=Your Job Title
OWNER_EMPLOYER=Your Employer
OWNER_BACKGROUND=Brief professional background
