# Telegram Agent environment — copy to agent.env and fill in values
TELEGRAM_BOT_TOKEN=          # From @BotFather
TELEGRAM_OWNER_ID=           # Your Telegram user ID (message bot, check docker logs)
TELEGRAM_WEBHOOK_SECRET=     # Any secret string — sent in X-Telegram-Bot-Api-Secret-Token header

# Windmill
WM_BASE_URL=http://windmill_server:8000
WM_WORKSPACE=admins
WM_TOKEN=wmill-api-XXXXXXXXXX

# Portfolio DB (internal Docker hostname)
AGENT_DB_URL=postgresql://portfolio_user:PASSWORD@portfolio_postgres:5432/portfolio

# LLM keys
DEEPSEEK_KEY=
XAI_KEY=
# W2 tool API keys
FINNHUB_KEY=
EXA_KEY=
FRED_KEY=

# Telegram group chat ID for draft approvals (negative int — fill after creating group with bot)
DRAFTS_GROUP_ID=
